# Copy to .env and fill in.
# Set DEFAULT_GEMINI_API_KEY so the API works without clients sending X-Gemini-Key.
# Optional: clients may still send X-Gemini-Key / X-Groq-Key to override per request.

DEFAULT_GEMINI_API_KEY=
DEFAULT_GROQ_API_KEY=

# Persistence (default: local async SQLite)
# Local SQLite (default, used when this is unset):
# DATABASE_URL=sqlite+aiosqlite:///parikshamitra.db
#
# Turso / libSQL cloud (production - Hugging Face Space). Get the URL from
# `turso db show <name> --url` and the token from `turso db tokens create <name>`,
# then concatenate them as below. Detected automatically by app/db/session.py.
# Requires Python 3.11-3.13 (sqlalchemy-libsql wheels) - the Docker image satisfies this.
# DATABASE_URL=libsql://parikshamitra-yourorg.turso.io?authToken=eyJhbGciOi...

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DEBUG=true
