# Local virtualenvs
.venv/
venv/
env/

# Python caches
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local databases (fresh DB created at boot inside container)
*.db
*.db-journal
*.db-wal
*.db-shm

# Vector store - rebuilt from PDFs at first ingestion
chroma_store/

# Secrets - HF Space env vars are injected at runtime
.env
.env.*
!.env.example

# Tests / dev tooling
tests/
.coverage
htmlcov/

# Editor / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db

# Build artefacts not needed in image
*.egg-info/
build/
dist/
*.log
